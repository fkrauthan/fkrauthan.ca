{
  "name": "fkrauthan.ca",
  "version": "1.0.0",
  "description": "The fkrauthan.ca website",
  "main": "NONE",
  "author": "Florian Krauthan <mail@fkrauthan.de>",
  "license": "NONE",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "postbuild": "find out -type f \\( -name '*.html' -o -name '*.css' -o -name '*.js' -o -name '*.json' -o -name '*.svg' \\) -exec gzip -9 -k {} \\; -exec brotli -9 -k {} \\;",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "serve": "serve ./out",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "postcss": "^8.5.14",
    "remark-parse": "^11.0.0",
    "tailwindcss": "^3.4.19",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@iconify-json/ion": "^1.2.7",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.0.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.3.3",
    "serve": "^14.2.6",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "unplugin-icons": "^22.5.0",
    "vite": "^6.0.11"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0",
    "yarn": "please-use-pnpm",
    "npm": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
